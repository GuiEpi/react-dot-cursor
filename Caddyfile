# Serves the static site on :8081, plain HTTP. HTTPS for react-dot-cursor.guics.st
# is terminated by the shared edge Caddy (immopad-bot-trafic-tracker's caddy service),
# which reaches this container over the external `edge` docker network.

:8081 {
	root * /usr/share/caddy
	encode gzip zstd
	try_files {path} /index.html
	file_server
}
