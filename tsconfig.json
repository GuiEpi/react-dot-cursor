{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    // tsup's DTS build injects the deprecated baseUrl option; tolerated until TS 7
    "ignoreDeprecations": "6.0"
  },
  "include": ["src"],
  "exclude": ["website"]
}
